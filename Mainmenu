#!/bin/bash
export LANG=en_US.UTF-8

# COLORS - RED THEME
R="\e[1;31m"
G="\e[1;32m"
Y="\e[1;33m"
B="\e[1;34m"
C="\e[1;36m"
M="\e[1;35m"
W="\e[1;37m"
N="\e[0m"

# TYRKROX ASCII ART
print_logo() {
echo -e "\n${R}╔════════════════════════════════════════════════════╗${N}"
echo -e "${R}║   ████████╗██╗   ██╗██████╗ ██╗  ██╗ ██████╗ ██╗  ██╗ ║${N}"
echo -e "${R}║   ╚══██╔══╝╚██╗ ██╔╝██╔══██╗██║ ██╔╝██╔═══██╗╚██╗██╔╝ ║${N}"
echo -e "${R}║      ██║    ╚████╔╝ ██████╔╝█████╔╝ ██║   ██║ ╚███╔╝  ║${N}"
echo -e "${R}║      ██║     ╚██╔╝  ██╔══██╗██╔═██╗ ██║   ██║ ██╔██╗  ║${N}"
echo -e "${R}║      ██║      ██║   ██║  ██║██║  ██╗╚██████╔╝██╔╝ ██╗ ║${N}"
echo -e "${R}║      ╚═╝      ╚═╝   ╚═╝  ╚═╝╚═╝  ╚═╝ ╚═════╝ ╚═╝  ╚═╝ ║${N}"
echo -e "${R}║                     T Y R K R O X                      ║${N}"
echo -e "${R}╚════════════════════════════════════════════════════╝${N}\n"
}

print_header() {
clear
print_logo
echo -e "${W}            DEVELOPMENT MANAGEMENT CONSOLE${N}"
echo -e "${R}════════════════════════════════════════════════════${N}\n"
}

while true; do
print_header

echo -e "${G}1) 🚀 GitHub VPS Maker${N}"
echo -e "${G}2) 🔧 IDX Tool Setup${N}"
echo -e "${G}3) ⚡ IDX VPS Maker${N}"
echo -e "${G}4) 🌐 Real VPS (Any + KVM)${N}"
echo -e "${G}5) ❌ Exit${N}"
echo ""

read -p "Select Option [1-5]: " op

case $op in

1)
echo -e "\n${Y}Launching GitHub VPS...${N}\n"
docker run -it --rm \
  --device /dev/kvm \
  hopingboyz/debain12
read -p "Press Enter to return..."
;;

2)
echo -e "\n${Y}Setting up IDX Tool...${N}\n"
mkdir -p ~/vps123/.idx
cd ~/vps123/.idx || exit
cat <<EOF > dev.nix
{ pkgs, ... }: {
  channel = "stable-24.05";
  packages = with pkgs; [ unzip git qemu_kvm sudo ];
}
EOF
echo -e "${G}IDX Setup Complete!${N}"
read -p "Press Enter to return..."
;;

3)
echo -e "\n${Y}Running IDX VPS Maker...${N}\n"
bash <(curl -s https://raw.githubusercontent.com/jishnu-limited/app-build-journey/main/vpmakerkvmidx)
read -p "Press Enter to return..."
;;

4)
echo -e "\n${Y}Launching Real VPS Installer...${N}\n"
bash <(curl -s https://raw.githubusercontent.com/nobita329/The-Coding-Hub/main/srv/vm/dd.sh)
bash <(curl -s https://raw.githubusercontent.com/JishnuTheGamer/Vps/main/n)
read -p "Press Enter to return..."
;;

5)
echo -e "\n${R}Exiting TYRKROX...${N}\n"
sleep 1
exit 0
;;

*)
echo -e "${R}Invalid Option!${N}"
sleep 1
;;

esac
done
