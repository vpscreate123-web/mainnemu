echo "║     ██║     ╚██╔╝  ██╔══██╗██╔═██╗ ██║   ██║ ██╔██╗  ║"
echo "║     ██║      ██║   ██║  ██║██║  ██╗╚██████╔╝██╔╝ ██╗ ║"
